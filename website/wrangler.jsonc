{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "pinboardshot",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-07-14",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "routes": [
    {
      "pattern": "pinboardshot.agentclub.dev",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
